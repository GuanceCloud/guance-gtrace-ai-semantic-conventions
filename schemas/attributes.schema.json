{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/GuanceCloud/gtrace-ai-semantic-conventions/schemas/attributes.schema.json",
  "title": "GTrace AI Trace Example",
  "type": "object",
  "required": ["trace_id", "spans"],
  "properties": {
    "trace_id": { "type": "string" },
    "resource": {
      "type": "object",
      "additionalProperties": true
    },
    "spans": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name", "span_id", "attributes"],
        "properties": {
          "name": { "type": "string" },
          "span_id": { "type": "string" },
          "parent_span_id": { "type": ["string", "null"] },
          "attributes": {
            "type": "object",
            "required": ["gen_ai.operation.name"],
            "properties": {
              "gen_ai.operation.name": {
                "type": "string",
                "enum": ["chat", "create_agent", "create_memory", "create_memory_store", "delete_memory", "delete_memory_store", "embeddings", "execute_tool", "generate_content", "invoke_agent", "invoke_workflow", "plan", "retrieval", "search_memory", "text_completion", "update_memory", "upsert_memory"]
              },
              "gen_ai.token.type": {
                "type": "string",
                "enum": ["input", "output"]
              },
              "skill.result.status": {
                "type": "string",
                "enum": ["completed", "error", "cancelled"]
              }
            },
            "not": {
              "anyOf": [
                { "required": ["gen_ai.usage.total_tokens"] },
                { "required": ["gen_ai.skill1.name"] },
                { "required": ["gen_ai.skill1.description"] },
                { "required": ["gen_ai.skill1.path"] },
                { "required": ["gen_ai.skill1.source.type"] },
                { "required": ["gen_ai.skill1.result_status"] },
                { "required": ["gen_ai.skill1.version"] }
              ]
            },
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
